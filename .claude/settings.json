{
  "permissions": {
    "allow": [
      "Bash(powershell -Command *)",
      "Bash(grep -rn * docs/stm32/**)",
      "Bash(grep -l * build/**/*.html)",
      "Bash(xargs grep *)",
      "Bash(grep -o *)",
      "Edit(/.claude/skills/migrate-obsidian-docs/**)",
      "WebSearch",
      "Bash(npm *)",
      "Bash(npx docusaurus *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-md.py\""
          }
        ]
      }
    ]
  }
}